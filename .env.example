# IntegriShield — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to Git.

# ── Redis (Event Bus — POC) ──
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ──
DATABASE_URL=postgresql://integrishield:integrishield_dev@localhost:5432/integrishield

# ── Event Stream Keys ──
STREAM_API_CALLS=integrishield:api_call_events
STREAM_ANOMALIES=integrishield:anomaly_scores
STREAM_SAP_MCP=integrishield:sap_mcp_events
STREAM_ALERTS=integrishield:alert_events
STREAM_ZERO_TRUST=integrishield:zero_trust_events
STREAM_CREDENTIALS=integrishield:credential_events
STREAM_CLOUD_POSTURE=integrishield:cloud_posture_events
REDIS_START_ID=$

# ── Module Ports ──
M04_PORT=8004
M05_PORT=8005
M06_PORT=8006
M07_PORT=8007
M10_PORT=8010
M12_PORT=8012
M13_PORT=8013
M15_PORT=8015

# ── Module-specific ──
M12_BULK_EXTRACTION_BYTES=10000000
M04_RISK_THRESHOLD_BLOCK=50
M06_MAX_SECRET_AGE_DAYS=30
M15_SUPPORTED_PROVIDERS=aws,gcp,azure

# ── Dev3 — M05 SAP MCP Suite ──
M05_REDIS_URL=redis://localhost:6379/0
M05_PUBLISH_STREAM=integrishield:mcp_query_events
M05_CONSUME_STREAMS=integrishield:api_call_events,integrishield:anomaly_events,integrishield:dlp_alerts,integrishield:alert_events
M05_CONSUMER_GROUP=m05-mcp-suite-cg
M05_EVENT_CACHE_SIZE=1000

# ── Dev3 — M07 Compliance Autopilot ──
M07_REDIS_URL=redis://localhost:6379/0
M07_DATABASE_URL=postgresql://integrishield:integrishield_dev@localhost:5432/integrishield
M07_PUBLISH_EVIDENCE_STREAM=integrishield:compliance_evidence
M07_PUBLISH_ALERT_STREAM=integrishield:compliance_alerts
M07_CONTROLS_CONFIG_PATH=./config/controls
M07_CONSUMER_GROUP=m07-compliance-autopilot-cg

# ── Dev3 — M10 Incident Response ──
M10_REDIS_URL=redis://localhost:6379/0
M10_DATABASE_URL=postgresql://integrishield:integrishield_dev@localhost:5432/integrishield
M10_PUBLISH_STREAM=integrishield:incident_events
M10_AUTO_CONTAIN_SEVERITY=critical
M10_MIN_SEVERITY_FOR_INCIDENT=medium
M10_SLACK_WEBHOOK_URL=
M10_PAGERDUTY_ROUTING_KEY=
M10_SIEM_ENDPOINT=

# ── Dev3 — M13 SBOM Scanner ──
M13_REDIS_URL=redis://localhost:6379/0
M13_PUBLISH_STREAM=integrishield:sbom_scan_events
M13_MAX_SCAN_SIZE_BYTES=5242880
M13_MAX_CONCURRENT_SCANS=10
M13_CVE_STUBS_PATH=./config/cve_stubs.json

# ── Kafka (MVP — not used in POC) ──
# EVENT_BUS=redis
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# SCHEMA_REGISTRY_URL=http://localhost:8081
