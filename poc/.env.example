# IntegriShield POC — environment variables
# Copy to .env and set before running docker-compose.
# All values below are safe POC defaults — change for production.

# ── Shared infrastructure ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
LOG_LEVEL=INFO

# ── Dev 1 — M01 API Gateway Shield ────────────────────────────────────────
# API key for authenticating calls to M01's /rfc/proxy endpoint.
# Comma-separate multiple keys for rotation:  key1,key2,key3
INTEGRISHIELD_API_KEYS=poc-dev-key-abc123

# Postgres connection string (matches docker-compose postgres service)
DATABASE_URL=postgresql://integrishield:integrishield_dev@postgres:5432/integrishield

# SAP backend URL — points to mock-sap in POC, real SAP gateway post-funding
SAP_BACKEND_URL=http://mock-sap:8080

# Rows-returned threshold above which a call is flagged as bulk extraction
BULK_ROW_THRESHOLD=10000

# Seconds before M01 gives up waiting for the SAP backend
SAP_TIMEOUT_S=30

# ── Dev 1 — Mock SAP backend ───────────────────────────────────────────────
MOCK_SAP_BULK_ROWS=80000
MOCK_SAP_NORMAL_ROWS=500
MOCK_SAP_LATENCY_MS=120

# ── Dev 2 — DLP thresholds ────────────────────────────────────────────────
HIGH_ROW_COUNT_THRESHOLD=10000
BLOCKLIST_ROW_THRESHOLD=5000
VELOCITY_THRESHOLD=50

# ── Dev 2 — Seed injector pacing ──────────────────────────────────────────
INJECT_DELAY_MS=200
