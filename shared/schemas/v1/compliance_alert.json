{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComplianceAlert",
  "description": "Compliance violation alert published by M07 Compliance Autopilot when a control is violated.",
  "type": "object",
  "required": ["event_id", "control_id", "framework", "violation_summary", "timestamp_utc"],
  "properties": {
    "event_id":          { "type": "string" },
    "control_id":        { "type": "string", "description": "Control that was violated" },
    "framework":         { "type": "string", "enum": ["sox", "soc2", "iso27001", "gdpr"] },
    "violation_summary": { "type": "string", "description": "Human-readable violation description" },
    "severity":          { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "tenant_id":         { "type": "string" },
    "timestamp_utc":     { "type": "string", "format": "date-time" },
    "source_module":     { "type": "string" }
  },
  "additionalProperties": false
}
