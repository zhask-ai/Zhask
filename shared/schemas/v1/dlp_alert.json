{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DlpAlert",
  "description": "Data Loss Prevention alert published by M9 to the dlp_alerts stream.",
  "type": "object",
  "required": ["alert_id", "original_event_id", "rfc_function", "client_ip", "user_id", "timestamp", "rule_triggered", "rows_returned", "threshold"],
  "properties": {
    "alert_id": { "type": "string" },
    "original_event_id": { "type": "string" },
    "rfc_function": { "type": "string" },
    "client_ip": { "type": "string" },
    "user_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "rule_triggered": {
      "type": "string",
      "enum": ["HIGH_ROW_COUNT", "BLOCKLISTED_FUNCTION", "VELOCITY_SPIKE"],
      "description": "Which DLP rule was violated"
    },
    "rows_returned": { "type": "integer", "minimum": 0 },
    "threshold": {
      "type": "integer",
      "description": "The threshold value that was exceeded"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM"]
    }
  },
  "additionalProperties": false
}
