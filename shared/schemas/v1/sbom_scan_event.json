{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SbomScanEvent",
  "description": "Scan completion event published by M13 SBOM Scanner.",
  "type": "object",
  "required": ["event_id", "scan_id", "filename", "total_findings", "critical_findings", "status", "timestamp_utc"],
  "properties": {
    "event_id":          { "type": "string" },
    "scan_id":           { "type": "string" },
    "filename":          { "type": "string", "description": "Name of the scanned ABAP file" },
    "tenant_id":         { "type": "string" },
    "total_findings":    { "type": "integer", "minimum": 0 },
    "critical_findings": { "type": "integer", "minimum": 0 },
    "status":            { "type": "string", "enum": ["complete", "failed"] },
    "timestamp_utc":     { "type": "string", "format": "date-time" },
    "source_module":     { "type": "string" }
  },
  "additionalProperties": false
}
