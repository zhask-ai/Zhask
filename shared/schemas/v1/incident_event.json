{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IncidentEvent",
  "description": "Incident lifecycle event published by M10 Incident Response.",
  "type": "object",
  "required": ["event_id", "incident_id", "alert_event_id", "action", "severity", "timestamp_utc"],
  "properties": {
    "event_id":       { "type": "string" },
    "incident_id":    { "type": "string" },
    "alert_event_id": { "type": "string", "description": "ID of the source alert that triggered this incident" },
    "action":         { "type": "string", "enum": ["created", "status_changed", "contained", "resolved"] },
    "severity":       { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "tenant_id":      { "type": "string" },
    "timestamp_utc":  { "type": "string", "format": "date-time" },
    "source_module":  { "type": "string" }
  },
  "additionalProperties": false
}
