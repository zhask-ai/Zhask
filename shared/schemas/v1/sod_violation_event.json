{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SoDViolationEvent",
  "type": "object",
  "required": ["violation_id", "tenant_id", "sap_user", "risk_id", "severity", "conflicting_tcodes", "detected_at"],
  "properties": {
    "violation_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "sap_user": {"type": "string"},
    "risk_id": {"type": "string"},
    "risk_title": {"type": "string"},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "conflicting_tcodes": {"type": "array", "items": {"type": "string"}},
    "roles_involved": {"type": "array", "items": {"type": "string"}},
    "first_detected_at": {"type": "string", "format": "date-time"},
    "detected_at": {"type": "string", "format": "date-time"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}}
  }
}
